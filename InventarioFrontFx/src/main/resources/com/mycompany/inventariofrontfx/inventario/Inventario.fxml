<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    CAMBIOS RESPECTO AL FXML ORIGINAL:
    1. Barra de paginación añadida al final de la tabla:
         [← Anterior]  spinner  Página 1 / 20  (500 equipos)  [Siguiente →]
       fx:id: btnAnterior, progressCarga, lblPagina, lblTotal, btnSiguiente.
    2. El Label "Mostrando resultados..." se reemplazó por lblTotal (conteo real).
    3. Todos los filtros y columnas son idénticos al original.
-->

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="0.0" minWidth="0.0" stylesheets="@inventario.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.inventariofrontfx.inventario.InventarioController">

    <!-- ============ ENCABEZADO / FILTROS ============ -->
    <top>
        <VBox nodeOrientation="LEFT_TO_RIGHT" spacing="15.0" styleClass="panel-menu" BorderPane.alignment="CENTER">
            <children>

                <!-- Título + botón agregar -->
                <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="panel-menu">
                    <children>
                        <Label maxWidth="1.7976931348623157E308" text="Filtros avanzados" HBox.hgrow="ALWAYS">
                            <font><Font name="SansSerif Bold" size="16.0" /></font>
                        </Label>
                        <Button fx:id="btnAgregar" mnemonicParsing="false" onAction="#agregarEquipo" prefHeight="40.0" prefWidth="230.0" styleClass="btn-agregar" text="+ Agregar Nuevo Equipo" textFill="WHITE">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Button>
                    </children>
                    <padding><Insets left="10.0" right="10.0" /></padding>
                </HBox>

                <!-- Filtros -->
                <FlowPane hgap="15.0" styleClass="panel-menu" vgap="10.0">
                    <children>
                        <TextField fx:id="txtFiltro" prefHeight="40.0" prefWidth="220.0" promptText="Buscar por GRY o Modelo" />
                    </children>
                    <padding><Insets left="10.0" right="10.0" /></padding>
                </FlowPane>

            </children>
            <padding><Insets bottom="10.0" top="10.0" /></padding>
        </VBox>
    </top>

    <!-- ============ TABLA + PAGINACIÓN ============ -->
    <center>
        <VBox spacing="10.0" styleClass="panel-menu" BorderPane.alignment="CENTER">
            <children>

                <!-- Tabla -->
                <TableView fx:id="tablaEquipos" styleClass="mi-tabla" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId" editable="false" prefWidth="60.0" sortable="false" text="ID" />
                        <TableColumn fx:id="colGry" editable="false" prefWidth="120.0" sortable="false" text="GRY" />
                        <TableColumn fx:id="colTipo" editable="false" prefWidth="120.0" sortable="false" text="Tipo Equipo" />
                        <TableColumn fx:id="colFecha" editable="false" prefWidth="120.0" sortable="false" text="Fecha Compra" />
                        <TableColumn fx:id="colModelo" editable="false" prefWidth="120.0" sortable="false" text="Modelo" />
                        <TableColumn fx:id="colCondicion" editable="false" prefWidth="100.0" sortable="false" text="Condición" />
                        <TableColumn fx:id="colEstado" editable="false" prefWidth="100.0" sortable="false" text="Estado" />
                        <TableColumn fx:id="colAcciones" editable="false" prefWidth="120.0" sortable="false" text="Acciones" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <!-- ════ BARRA DE PAGINACIÓN ════════════════════════════════
                     [← Anterior]  🔄  Página 1 / 20   500 equipos  [Siguiente →]
                ═══════════════════════════════════════════════════════════ -->
                <HBox alignment="CENTER" spacing="12.0" style="-fx-background-color: #F8FAFC;                              -fx-border-color: #E5E7EB;                              -fx-border-width: 1 0 0 0;                              -fx-padding: 8 12;">

                    <Button fx:id="btnAnterior" disable="true" onAction="#irAPaginaAnterior" prefHeight="34.0" styleClass="btn-cancelar" text="Anterior" />

                    <ProgressIndicator fx:id="progressCarga" managed="false" prefHeight="24.0" prefWidth="24.0" visible="false" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Label fx:id="lblPagina" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #374151;" text="Página 1 / 1" />

                    <Label fx:id="lblTotal" style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" text="0 equipos" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="btnSiguiente" disable="true" onAction="#irAPaginaSiguiente" prefHeight="34.0" styleClass="btn-agregar" text="Siguiente" />

                </HBox>

            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" />
            </padding>
        </VBox>
    </center>

</BorderPane>
