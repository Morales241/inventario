<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<FlowPane hgap="20.0" styleClass="panel-isla" stylesheets="@inventario.css" vgap="15.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.inventariofrontfx.inventario.InfoEspecificaEscritorioController">
   <children>
      
      <VBox spacing="5.0">
         <children>
            <Label text="Nombre de equipo:" />
            <TextField fx:id="txtNombreEquipo" prefHeight="35.0" prefWidth="300.0" />
         </children>
      </VBox>

      <VBox spacing="5.0">
         <children>
            <Label text="Usuario de red:" />
            <TextField fx:id="txtCuentaEquipo" prefHeight="35.0" prefWidth="300.0" />
         </children>
      </VBox>

      <VBox spacing="5.0">
         <children>
            <Label text="Final de la garantía:" />
            <DatePicker fx:id="fechaGarantia" prefHeight="35.0" prefWidth="300.0" />
         </children>
      </VBox>
      <VBox prefHeight="50.0" prefWidth="140.0" spacing="5.0">
         <children>
            <Label text="Mouse:" />
            <HBox alignment="CENTER" prefHeight="35.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5;">
               <children>
                  <RadioButton fx:id="rbtManosLibres" mnemonicParsing="false" text="SI">
                     <toggleGroup>
                        <ToggleGroup fx:id="grupo2" />
                     </toggleGroup>
                  </RadioButton>
                  <RadioButton mnemonicParsing="false" selected="true" text="NO" toggleGroup="$grupo2" />
               </children>
               <padding>
                  <Insets left="10.0" right="10.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
      <VBox prefHeight="60.0" prefWidth="140.0" spacing="5.0">
         <children>
            <Label text="Mochila:" />
            <HBox alignment="CENTER" prefHeight="35.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 5; -fx-border-color: #cccccc; -fx-border-radius: 5;">
               <children>
                  <RadioButton fx:id="rbtManosLibres1" mnemonicParsing="false" text="SI">
                     <toggleGroup>
                        <ToggleGroup fx:id="grupo21" />
                     </toggleGroup>
                  </RadioButton>
                  <RadioButton mnemonicParsing="false" selected="true" text="NO" toggleGroup="$grupo21" />
               </children>
               <padding>
                  <Insets left="10.0" right="10.0" />
               </padding>
            </HBox>
         </children>
      </VBox>
      <VBox prefHeight="55.0" prefWidth="300.0">
         <children>
            <Label text="Sistema operativo" />
            <ComboBox prefHeight="35.0" prefWidth="300.0" />
         </children>
      </VBox>

   </children>
   <padding>
      <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
   </padding>
</FlowPane>
