<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<ScrollPane fitToWidth="true" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/11" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.inventariofrontfx.PrimaryController">
    <content>
        <GridPane hgap="20" vgap="20" style="-fx-background-color: #f0f2f5; -fx-padding: 30;">
            
            <columnConstraints>
                <ColumnConstraints percentWidth="50" /> <ColumnConstraints percentWidth="50" /> </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="SOMETIMES" /> <RowConstraints vgrow="SOMETIMES" /> </rowConstraints>

            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0); -fx-padding: 20;" GridPane.columnIndex="0" GridPane.rowIndex="0">
                <Label text="1. Información del Activo" textFill="#2980b9">
                    <font><Font name="System Bold" size="16.0" /></font>
                </Label>
                <Separator />
                
                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10" prefWidth="100" />
                    </columnConstraints>

                    <Label text="No. Serie:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                    <TextField fx:id="txtNoSerie" promptText="S/N del fabricante" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                    <Label text="GRI (ID Interno):" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                    <TextField fx:id="txtGRI" promptText="Código de etiqueta" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                    <Label text="Condición:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                    <ComboBox fx:id="cbxCondicion" maxWidth="Infinity" GridPane.rowIndex="2" GridPane.columnIndex="1" />

                    <Label text="Factura:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                    <TextField fx:id="txtFactura" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                    
                    <Label text="Fecha Compra:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                    <DatePicker fx:id="fechaCompra" maxWidth="Infinity" GridPane.rowIndex="4" GridPane.columnIndex="1" />
                </GridPane>
            </VBox>

            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0); -fx-padding: 20;" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="2. Definición del Modelo" textFill="#2980b9">
                        <font><Font name="System Bold" size="16.0" /></font>
                    </Label>
                    <CheckBox fx:id="chkNuevoModelo" text="Crear Nuevo" textFill="#7f8c8d" />
                </HBox>
                <Separator />

                <Label text="Seleccionar Modelo Existente:" style="-fx-font-size: 11px; -fx-text-fill: #7f8c8d;" />
                <ComboBox fx:id="cbxModelosExistentes" maxWidth="Infinity" promptText="Buscar modelo..." />
                
                <Label text="Detalles del Modelo:" style="-fx-padding: 10 0 0 0;" />
                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="80" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    
                    <Label text="Marca:" GridPane.rowIndex="0" />
                    <TextField fx:id="txtMarca" disable="true" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                    <Label text="Nombre Modelo:" GridPane.rowIndex="1" />
                    <TextField fx:id="txtNombreModelo" disable="true" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                </GridPane>
            </VBox>

            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0); -fx-padding: 20;" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="3. Especificaciones Técnicas" textFill="#2980b9">
                    <font><Font name="System Bold" size="16.0" /></font>
                </Label>
                <Separator />
                
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Tipo de Equipo:" />
                    <ComboBox fx:id="cbxTipoEquipo" prefWidth="200" />
                </HBox>

                <GridPane fx:id="panelSpecsPC" hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="100" />
                        <ColumnConstraints hgrow="ALWAYS" minWidth="10" prefWidth="100" />
                    </columnConstraints>

                    <Label text="Procesador:" GridPane.rowIndex="0" />
                    <TextField fx:id="txtProcesador" promptText="Ej: Intel Core i5" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                    <Label text="Memoria RAM:" GridPane.rowIndex="1" />
                    <TextField fx:id="txtRam" promptText="Ej: 16 GB" GridPane.rowIndex="1" GridPane.columnIndex="1" />

                    <Label text="Almacenamiento:" GridPane.rowIndex="2" />
                    <TextField fx:id="txtAlmacenamiento" promptText="Ej: 512 GB SSD" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                </GridPane>
            </VBox>

            <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0); -fx-padding: 20;" GridPane.columnIndex="1" GridPane.rowIndex="1">
                <Label text="4. Ubicación y Finalización" textFill="#2980b9">
                    <font><Font name="System Bold" size="16.0" /></font>
                </Label>
                <Separator />

                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="80" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>

                    <Label text="Empresa:" GridPane.rowIndex="0" />
                    <ComboBox fx:id="cbxEmpresa" maxWidth="Infinity" GridPane.rowIndex="0" GridPane.columnIndex="1" />

                    <Label text="Sucursal:" GridPane.rowIndex="1" />
                    <ComboBox fx:id="cbxSucursal" maxWidth="Infinity" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                </GridPane>

                <Label text="Observaciones:" />
                <TextArea fx:id="txtObservaciones" prefRowCount="3" wrapText="true" />

                <Region VBox.vgrow="ALWAYS" />

                <HBox alignment="CENTER_RIGHT" spacing="15">
                    <Button text="Cancelar" style="-fx-background-color: transparent; -fx-text-fill: #7f8c8d; -fx-cursor: hand;" />
                    <Button text="GUARDAR EQUIPO" onAction="#guardarInventario" 
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-padding: 10 20; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 5, 0, 0, 1);" />
                </HBox>
            </VBox>

        </GridPane>
    </content>
</ScrollPane>