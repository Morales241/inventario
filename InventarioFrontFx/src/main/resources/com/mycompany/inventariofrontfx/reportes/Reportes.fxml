<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.web.WebView?>

<BorderPane fx:id="rootPane" prefHeight="600.0" prefWidth="800.0" 
            xmlns="http://javafx.com/javafx/18" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.mycompany.inventario.reportes.ReporteViewerController">
    
    <top>
        <ToolBar>
            <HBox alignment="CENTER_LEFT" spacing="5">
                <Button fx:id="btnCerrar" mnemonicParsing="false" text="Cerrar" />
                <Button fx:id="btnImprimir" mnemonicParsing="false" text="Imprimir" />
                <Button fx:id="btnExportar" mnemonicParsing="false" text="Exportar PDF" />
            </HBox>
            
            <HBox alignment="CENTER_RIGHT" spacing="5" HBox.hgrow="ALWAYS">
                <Button fx:id="btnZoomOut" mnemonicParsing="false" text="-" />
                <Button fx:id="btnZoomIn" mnemonicParsing="false" text="+" />
            </HBox>
        </ToolBar>
    </top>
    
    <center>
        <StackPane>
            <WebView fx:id="webView" />
            <ProgressIndicator fx:id="progressIndicator" visible="false" />
        </StackPane>
    </center>
    
</BorderPane>