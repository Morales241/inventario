<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="1.7976931348623157E308"
            maxWidth="1.7976931348623157E308"
            styleClass="panel-menu"
            stylesheets="@../estilos-base.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.inventariofrontfx.cuentas.CuentasController">

    <top>
        <VBox spacing="10.0" styleClass="panel-menu" BorderPane.alignment="CENTER">
            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="10.0" /></padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <TextField fx:id="txtFiltro"
                                   prefHeight="38.0" prefWidth="280.0"
                                   promptText="🔍 Buscar por username..." />
                        <Region HBox.hgrow="ALWAYS" />
                        <Button text="＋ Nueva Cuenta"
                                styleClass="btn-agregar"
                                onAction="#modoNuevo"
                                prefHeight="38.0" prefWidth="160.0">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>

    <center>
        <VBox spacing="10.0" styleClass="panel-menu" BorderPane.alignment="CENTER">
            <padding><Insets bottom="10.0" left="15.0" right="15.0" top="5.0" /></padding>
            <children>
                <TableView fx:id="tablaCuentas"
                           styleClass="mi-tabla"
                           VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId"
                                     text="ID"
                                     prefWidth="60.0" maxWidth="100.0"
                                     sortable="false" editable="false" />
                        <TableColumn fx:id="colUsername"
                                     text="Usuario"
                                     prefWidth="200.0"
                                     sortable="false" editable="false" />
                        <TableColumn fx:id="colRol"
                                     text="Rol"
                                     prefWidth="160.0"
                                     sortable="false" editable="false" />
                        <TableColumn fx:id="colAcciones"
                                     text="Acciones"
                                     prefWidth="120.0"
                                     sortable="false" editable="false"
                                     resizable="false" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </center>

    <right>
        <VBox spacing="16.0"
              prefWidth="290.0"
              styleClass="panel-isla"
              BorderPane.alignment="TOP_CENTER">
            <BorderPane.margin>
                <Insets bottom="10.0" right="10.0" top="10.0" />
            </BorderPane.margin>
            <padding><Insets bottom="20.0" left="18.0" right="18.0" top="18.0" /></padding>

            <children>

                <!-- Título del formulario -->
                <Label fx:id="lblTituloForm"
                       text="Nueva Cuenta"
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #13507d;" />

                <Separator />

                <!-- Username -->
                <VBox spacing="4">
                    <Label text="Usuario" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #374151;" />
                    <TextField fx:id="txtUsername"
                               prefHeight="36.0"
                               promptText="Nombre de usuario único" />
                    <Label fx:id="errUsername"
                           styleClass="label-error"
                           visible="false" managed="false" />
                </VBox>

                <!-- Contraseña -->
                <VBox spacing="4">
                    <Label text="Contraseña" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #374151;" />
                    <PasswordField fx:id="pfPassword"
                                   prefHeight="36.0"
                                   promptText="Mínimo 4 caracteres" />
                    <Label fx:id="lblPasswordHint"
                           style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"
                           visible="false" managed="false" />
                    <Label fx:id="errPassword"
                           styleClass="label-error"
                           visible="false" managed="false" />
                </VBox>

                <!-- Rol -->
                <VBox spacing="4">
                    <Label text="Rol de acceso" style="-fx-font-weight: bold; -fx-font-size: 12px; -fx-text-fill: #374151;" />
                    <ComboBox fx:id="cbxRol"
                              prefHeight="36.0"
                              maxWidth="1.7976931348623157E308"
                              promptText="Selecciona un rol" />
                    <Label fx:id="errRol"
                           styleClass="label-error"
                           visible="false" managed="false" />
                </VBox>

                <VBox spacing="6"
                      style="-fx-background-color: #F0F7FF; -fx-background-radius: 8; -fx-border-color: #BFDBFE; -fx-border-radius: 8; -fx-border-width: 1; -fx-padding: 10;">
                    <Label text="ℹ Roles disponibles"
                           style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-text-fill: #13507d;" />
                    <Label text="🔑 ADMIN — Acceso total"
                           style="-fx-font-size: 11px; -fx-text-fill: #374151;" />
                    <Label text="📦 ALMACENISTA — Equipos y asignaciones"
                           style="-fx-font-size: 11px; -fx-text-fill: #374151;" />
                    <Label text="👁 INVITADO — Solo lectura"
                           style="-fx-font-size: 11px; -fx-text-fill: #374151;" />
                </VBox>

                <!-- Botones -->
                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="8">
                    <Button fx:id="btnGuardar"
                            text="💾 Guardar Cuenta"
                            styleClass="btn-agregar"
                            onAction="#guardarCuenta"
                            maxWidth="1.7976931348623157E308"
                            prefHeight="40.0">
                        <font><Font name="System Bold" size="12.0" /></font>
                    </Button>
                    <Button fx:id="btnCancelar"
                            text="Cancelar"
                            styleClass="btn-cancelar"
                            onAction="#cancelarFormulario"
                            maxWidth="1.7976931348623157E308"
                            prefHeight="36.0" />
                </VBox>

            </children>
        </VBox>
    </right>

</BorderPane>
