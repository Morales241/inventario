	<title height="108">
		<element kind="staticText" x="80" y="15" width="400" height="32" forecolor="#13507D" fontSize="16.0" bold="true" hTextAlign="Center">
			<text><![CDATA[CARTA RESPONSIVA DE OTROS EQUIPOS]]></text>
		</element>
	</title>
	<detail>
		<band height="531">
			<element kind="staticText" x="0" y="8" width="572" height="20" forecolor="#13507D" backcolor="#E8F0F7" fontSize="11.0" bold="true">
				<text><![CDATA[  DATOS DEL USUARIO RESPONSABLE]]></text>
			</element>
			<element kind="staticText" x="10" y="32" width="130" height="18" fontSize="10.0" bold="true">
				<text><![CDATA[Nombre del Empleado:]]></text>
			</element>
			<element kind="textField" x="145" y="32" width="420" height="18">
				<expression><![CDATA[$P{nombreEmpleado} != null ? $P{nombreEmpleado} : ""]]></expression>
			</element>
			<element kind="staticText" x="10" y="52" width="70" height="18" fontSize="10.0" bold="true">
				<text><![CDATA[Puesto:]]></text>
			</element>
			<element kind="textField" x="85" y="52" width="480" height="18">
				<expression><![CDATA[$P{puesto} != null ? $P{puesto} : ""]]></expression>
			</element>
			<element kind="staticText" x="0" y="78" width="572" height="82" fontSize="9.0" hTextAlign="Justified">
				<text><![CDATA[El empleado arriba mencionado, declara bajo protesta de decir verdad, que recibe en este acto el equipo que se describe más adelante, comprometiéndose a utilizarlo única y exclusivamente para el desempeño de sus funciones dentro de la empresa Grupo Rio Yaqui, S.A. de C.V., así como a mantenerlo en óptimas condiciones de uso, limpieza y seguridad, reportando inmediatamente cualquier falla o daño que presente el mismo.

De igual forma, se compromete a no realizar modificaciones al equipo sin autorización expresa del Departamento de TI. En caso de incumplimiento, se aplicarán las sanciones correspondientes conforme al reglamento interno de la empresa.]]></text>
			</element>
			<element kind="staticText" x="0" y="170" width="572" height="20" forecolor="#13507D" backcolor="#E8F0F7" fontSize="11.0" bold="true">
				<text><![CDATA[  ESPECIFICACIONES DEL EQUIPO]]></text>
			</element>
			<element kind="textField" x="10" y="196" width="270" height="18" fontSize="10.0">
				<expression><![CDATA["GRY: " + ($P{gry} != null ? $P{gry}.toString() : "—")]]></expression>
			</element>
			<element kind="textField" x="300" y="196" width="265" height="18" fontSize="10.0">
				<expression><![CDATA["Marca: " + ($P{marca} != null ? $P{marca} : "—")]]></expression>
			</element>
			<element kind="textField" x="10" y="216" width="270" height="18" fontSize="10.0">
				<expression><![CDATA["Tipo: " + ($P{tipoEquipo} != null ? $P{tipoEquipo} : "—")]]></expression>
			</element>
			<element kind="textField" x="300" y="216" width="265" height="18" fontSize="10.0">
				<expression><![CDATA["Serie: " + ($P{numeroSerie} != null ? $P{numeroSerie} : "—")]]></expression>
			</element>
			<element kind="textField" x="10" y="236" width="270" height="18" fontSize="10.0">
				<expression><![CDATA["Modelo: " + ($P{modelo} != null ? $P{modelo} : "—")]]></expression>
			</element>
			<element kind="staticText" x="0" y="286" width="572" height="20" forecolor="#13507D" backcolor="#E8F0F7" fontSize="11.0" bold="true">
