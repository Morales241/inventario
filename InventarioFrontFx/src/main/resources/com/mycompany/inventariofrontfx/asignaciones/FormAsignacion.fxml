<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="650" prefWidth="1100" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.inventariofrontfx.asignaciones.AsignacionesController">

    <center>
        <VBox alignment="TOP_CENTER" spacing="25">

            <padding>
                <Insets bottom="35" left="30" right="30" top="25" />
            </padding>

            <VBox maxWidth="1025" spacing="25">

                <HBox alignment="CENTER" spacing="25">

                    <VBox maxWidth="500" prefWidth="500" spacing="15" styleClass="panel-card">
                        <padding>
                            <Insets bottom="20" left="20" right="20" top="20" />
                        </padding>

                        <Label styleClass="titulo-seccion" text="Seleccionar Trabajador" />

                        <TextField fx:id="txtBuscarUsuario" promptText="Buscar por nombre o numero de nomina" styleClass="input-busqueda" />

                        <ListView fx:id="listUsuarios" styleClass="lista-card" VBox.vgrow="ALWAYS" />
                    </VBox>

                    <VBox maxWidth="500" prefWidth="500" spacing="15" styleClass="panel-card">
                        <padding>
                            <Insets bottom="20" left="20" right="20" top="20" />
                        </padding>

                        <Label styleClass="titulo-seccion" text="Seleccionar Equipo" />

                        <TextField fx:id="txtBuscarEquipo" promptText="Buscar por serie o modelo" styleClass="input-busqueda" />

                        <ListView fx:id="listEquipos" styleClass="lista-card" VBox.vgrow="ALWAYS" />
                    </VBox>

                </HBox>

                <VBox maxWidth="Infinity" spacing="15" styleClass="panel-card">

                    <padding>
                        <Insets bottom="20" left="20" right="20" top="20" />
                    </padding>

                    <Label styleClass="titulo-seccion" text="Detalles de la Asignación" />

                    <HBox spacing="25">

                        <VBox minWidth="500.0" spacing="6">
                            <Label text="Fecha de Entrega *" />
                            <DatePicker fx:id="dateEntrega" minHeight="35.0" />
                        </VBox>

                        <VBox spacing="6">
                            <Label text="Fecha de Devolución (Opcional)" />
                            <DatePicker fx:id="dateRegreso" minHeight="35.0" />
                        </VBox>

                    </HBox>

                    <Button fx:id="btnConfirmar" maxWidth="1.7976931348623157E308" styleClass="btn-principal-grande" text="Confirmar Asignación" />
                </VBox>

            </VBox>

        </VBox>
    </center>

    <stylesheets>
        <URL value="@asignaciones.css" />
    </stylesheets>

</BorderPane>
