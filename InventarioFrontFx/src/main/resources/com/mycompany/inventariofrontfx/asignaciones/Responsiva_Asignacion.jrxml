			</element>
			<element kind="staticText" uuid="ff109be8-d259-49e8-9911-9d53965a7a9c" x="10" y="52" width="70" height="18" fontSize="10.0" bold="true">
				<text><![CDATA[Puesto:]]></text>
			</element>
			<element kind="textField" uuid="d1bb6875-b812-402a-ac02-fc2c4a94a379" x="85" y="52" width="480" height="18">
