<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="1.7976931348623157E308"
            maxWidth="1.7976931348623157E308"
            minHeight="0.0" minWidth="0.0"
            styleClass="panel-menu"
            stylesheets="@asignaciones.css"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.inventariofrontfx.asignaciones.AsignacionesController">

    <!-- ════════ ENCABEZADO ════════ -->
    <top>
        <VBox nodeOrientation="LEFT_TO_RIGHT" spacing="15.0"
              styleClass="panel-menu" BorderPane.alignment="CENTER">
            <children>

                <HBox alignment="CENTER_RIGHT" spacing="10.0" styleClass="panel-menu">
                    <children>
                        <Button fx:id="btnNuevaAsignacion"
                                mnemonicParsing="false"
                                onAction="#irANuevaAsignacion"
                                prefHeight="40.0" prefWidth="180.0"
                                styleClass="btn-agregar"
                                text="+ Nueva Asignación"
                                textFill="WHITE">
                            <font><Font name="System Bold" size="12.0" /></font>
                        </Button>
                    </children>
                    <padding><Insets left="10.0" right="10.0" /></padding>
                </HBox>

                <FlowPane hgap="15.0" styleClass="panel-menu" vgap="10.0">
                    <children>
                        <TextField fx:id="txtFiltro"
                                   prefHeight="40.0" prefWidth="300.0"
                                   promptText="Buscar por usuario o GRY..." />
                    </children>
                    <padding><Insets left="10.0" right="10.0" /></padding>
                </FlowPane>

            </children>
            <padding><Insets bottom="10.0" top="10.0" /></padding>
        </VBox>
    </top>

    <!-- ════════ TABLA + PAGINACIÓN ════════ -->
    <center>
        <VBox spacing="10.0" styleClass="panel-menu" BorderPane.alignment="CENTER">
            <children>

                <TableView fx:id="tablaAsignaciones"
                           styleClass="mi-tabla"
                           VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colId"
                                     editable="false" prefWidth="60.0"
                                     sortable="false" text="ID" />
                        <TableColumn fx:id="colEquipo"
                                     editable="false" prefWidth="150.0"
                                     sortable="false" text="Equipo (GRY)" />
                        <TableColumn fx:id="colUsuario"
                                     editable="false" prefWidth="200.0"
                                     sortable="false" text="Usuario" />
                        <TableColumn fx:id="colFechaEntrega"
                                     editable="false" prefWidth="120.0"
                                     sortable="false" text="Fecha Entrega" />
                        <TableColumn fx:id="colFechaDevolucion"
                                     editable="false" prefWidth="130.0"
                                     sortable="false" text="Fecha Devolución" />
                        <TableColumn fx:id="colEstado"
                                     editable="false" prefWidth="100.0"
                                     sortable="false" text="Estado" />
                        <TableColumn fx:id="colAcciones"
                                     editable="false" prefWidth="100.0"
                                     sortable="false" text="Acciones" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>

                <!-- ════ BARRA DE PAGINACIÓN ══════════════════════════════════
                     [← Anterior]  spinner  Página 1 / 8  (200 activas)  [Siguiente →]
                ═══════════════════════════════════════════════════════════ -->
                <HBox alignment="CENTER" spacing="12.0"
                      style="-fx-background-color: #F8FAFC;
                             -fx-border-color: #E5E7EB;
                             -fx-border-width: 1 0 0 0;
                             -fx-padding: 8 12;">

                    <Button fx:id="btnAnterior"
                            text="← Anterior"
                            styleClass="btn-cancelar"
                            disable="true"
                            onAction="#irAPaginaAnterior"
                            prefHeight="34.0" />

                    <ProgressIndicator fx:id="progressCarga"
                                       prefWidth="24.0" prefHeight="24.0"
                                       visible="false" managed="false" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Label fx:id="lblPagina"
                           text="Página 1 / 1"
                           style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #374151;" />

                    <Label fx:id="lblTotal"
                           text="0 activas"
                           style="-fx-font-size: 12px; -fx-text-fill: #6B7280;" />

                    <Region HBox.hgrow="ALWAYS" />

                    <Button fx:id="btnSiguiente"
                            text="Siguiente →"
                            styleClass="btn-agregar"
                            disable="true"
                            onAction="#irAPaginaSiguiente"
                            prefHeight="34.0" />

                </HBox>

            </children>
            <padding><Insets bottom="10.0" left="10.0" right="10.0" /></padding>
        </VBox>
    </center>

</BorderPane>
