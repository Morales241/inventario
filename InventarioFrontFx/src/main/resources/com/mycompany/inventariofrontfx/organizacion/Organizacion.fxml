<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" 
            stylesheets="@organizacion.css" 
            xmlns="http://javafx.com/javafx/21" 
            xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.mycompany.inventariofrontfx.organizacion.OrganizacionController">
    
    <top>
        <VBox spacing="10.0" styleClass="panel-superior">
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
            </padding>
            
            <children>
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Label style="-fx-font-size: 24px;" text="🏢" />
                    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #13507d;" 
                           text="ESTRUCTURA ORGANIZACIONAL" />
                </HBox>
                
                <Label text="Gestión de empresas, sucursales, departamentos y puestos" 
                       style="-fx-text-fill: #666666;" />
            </children>
        </VBox>
    </top>
    
    <center>
        <SplitPane dividerPositions="0.3">
            <!-- Panel izquierdo: Árbol jerárquico -->
            <VBox spacing="10.0" styleClass="panel-lateral">
                <padding>
                    <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                </padding>
                
                <children>
                    <Label text="ESTRUCTURA" style="-fx-font-weight: bold; -fx-text-fill: #13507d;" />
                    
                    <TreeView fx:id="treeOrganizacion" VBox.vgrow="ALWAYS" 
                              styleClass="arbol-organizacion" />
                    
                    <HBox spacing="10.0">
                        <Button fx:id="btnNuevo" styleClass="btn-agregar" text="+ Nuevo" 
                                maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnCancelar" styleClass="btn-cancelar" text="Limpiar" 
                                maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
                    </HBox>
                </children>
            </VBox>
            
            <!-- Panel derecho: Detalles y formularios -->
            <VBox spacing="15.0" styleClass="panel-card">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
                
                <children>
                    <Label fx:id="lblTituloDetalle" text="Seleccione un elemento" 
                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #13507d;" />
                    
                    <VBox fx:id="panelDetalle" spacing="10.0" VBox.vgrow="ALWAYS">
                        <!-- Aquí se insertan los campos dinámicamente -->
                    </VBox>
                </children>
            </VBox>
        </SplitPane>
    </center>
    
</BorderPane>