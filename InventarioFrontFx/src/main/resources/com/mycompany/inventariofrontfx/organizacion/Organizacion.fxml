<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<!--
    DISEÑO PROPUESTO — Organización
    ════════════════════════════════
    Layout: SplitPane 30/70

    PANEL IZQUIERDO (30%):
      • Buscador que filtra el árbol en tiempo real
      • TreeView con íconos por nivel (empresa, sucursal, departamento, puesto)
      • Botones [+ Nueva empresa] y [Limpiar selección]
      • Spinner de carga

    PANEL DERECHO (70%):
      Tiene 3 estados manejados por el controller:
        A) PLACEHOLDER — "Seleccione un elemento del árbol"
        B) DETALLE + FORMULARIO — campos para editar/crear la entidad seleccionada:
             • Breadcrumb visual: Empresa > Sucursal > Dpto > Puesto
             • Badge de tipo (chip de color)
             • Stat cards: N sucursales / N departamentos / N puestos / N empleados
             • Formulario con campos específicos del tipo
             • Botones [Guardar] [Eliminar]
             • Sección "Agregar hijo": botón contextual para añadir el nivel siguiente
        C) FORMULARIO NUEVO — misma estructura pero sin stat cards y sin botón eliminar

    IMPLEMENTACIÓN:
      El controller muestra/oculta estos sub-paneles con setVisible()/setManaged().
      Las secciones con fx:id son las que el controller manipula.
-->

<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" stylesheets="@organizacion.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mycompany.inventariofrontfx.organizacion.OrganizacionController">

    <!-- ════════════ SPLIT PRINCIPAL ════════════ -->
    <center>
        <SplitPane dividerPositions="0.3" style="-fx-background-color: #F3F4F6; -fx-padding: 10;">

            <!-- ══════ PANEL IZQUIERDO: ÁRBOL ══════ -->
            <VBox minWidth="200" spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">
                <padding><Insets bottom="12.0" left="12.0" right="12.0" top="12.0" /></padding>

                <children>

                    <!-- Título árbol -->
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-text-fill: #9CA3AF;" text="ESTRUCTURA" />
                        <Region HBox.hgrow="ALWAYS" />
                        <ProgressIndicator fx:id="progressArbol" managed="false" prefHeight="16" prefWidth="16" visible="false" />
                    </HBox>

                    <!-- Buscador -->
                    <TextField fx:id="txtBuscarArbol" promptText="Buscar..." style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-border-radius: 7; -fx-background-radius: 7; -fx-padding: 7 10; -fx-font-size: 12px;" />

                    <!-- Árbol -->
                    <TreeView fx:id="treeOrganizacion" styleClass="arbol-organizacion" VBox.vgrow="ALWAYS" />

                    <Separator />

                    <!-- Botones inferiores -->
                    <Button fx:id="btnNuevaEmpresa" maxWidth="1.7976931348623157E308" onAction="#nuevaEmpresa" prefHeight="36" styleClass="btn-agregar" text="Nueva Empresa" />

                    <Button fx:id="btnLimpiar" maxWidth="1.7976931348623157E308" onAction="#limpiarSeleccion" prefHeight="34" styleClass="btn-cancelar" text="Limpiar selección" />

                </children>
            </VBox>

            <!-- ══════ PANEL DERECHO: DETALLE / FORMULARIO ══════ -->
            <StackPane VBox.vgrow="ALWAYS">

                <!-- ─── ESTADO A: PLACEHOLDER (visible cuando nada seleccionado) ─── -->
                <VBox fx:id="panelPlaceholder" alignment="CENTER" spacing="16" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-border-width: 1.5; -fx-border-style: dashed;">
                    <Label fx:id="lblPlaceholderIcon" styleClass="placeholder-icon" text="" />
                    <Label styleClass="placeholder-text" text="Selecciona un elemento del árbol" />
                    <Label styleClass="placeholder-subtext" text="Haz clic en una empresa, sucursal, departamento o puesto para ver sus detalles" />
                    <Button onAction="#nuevaEmpresa" styleClass="btn-add-child" text="Crear primera empresa" />
                </VBox>

                <!-- ─── ESTADO B/C: PANEL DE DETALLE ─── -->
                <VBox fx:id="panelDetalle" managed="false" spacing="0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E5E7EB; -fx-border-radius: 12; -fx-border-width: 1; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);" visible="false">

                    <!-- Cabecera del detalle -->
                    <VBox spacing="10" style="-fx-padding: 20 24 16 24;">

                        <!-- Breadcrumb -->
                        <HBox fx:id="breadcrumbBox" alignment="CENTER_LEFT" spacing="4" styleClass="breadcrumb-box" />

                        <!-- Título + badge de tipo -->
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label fx:id="lblIconoTipo" style="-fx-font-size: 28px;" text="" />
                            <VBox spacing="3">
                                <Label fx:id="lblTituloDetalle" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #111827;" text="Empresa" />
                                <Label fx:id="lblBadgeTipo" styleClass="badge-empresa" text="EMPRESA" />
                            </VBox>
                            <Region HBox.hgrow="ALWAYS" />
                            <!-- Botón eliminar en cabecera -->
                            <Button fx:id="btnEliminar" managed="false" onAction="#eliminarSeleccionado" prefHeight="34" styleClass="btn-eliminar" text="Eliminar" visible="false" />
                        </HBox>

                        <!-- Stat cards (se ocultan en modo "nuevo") -->
                        <HBox fx:id="statsBox" managed="false" spacing="12" visible="false">
                            <!-- Los stat cards se generan dinámicamente desde el controller -->
                        </HBox>

                    </VBox>

                    <Separator />

                    <!-- Cuerpo del formulario (scroll) -->
                    <javafx.scene.control.ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                        <content>
                            <VBox fx:id="formBody" spacing="16" style="-fx-padding: 20 24;">

                                <!-- ─── CAMPOS COMUNES (siempre visibles) ─── -->
                                <VBox spacing="4">
                                    <Label styleClass="form-field-label" text="Nombre" />
                                    <TextField fx:id="txtNombre" prefHeight="38" promptText="Ingresa el nombre..." style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-size: 13px;" />
                                    <Label fx:id="errNombre" managed="false" styleClass="label-error" visible="false" />
                                </VBox>

                                <!-- ─── CAMPO UBICACIÓN (solo sucursal) ─── -->
                                <VBox fx:id="seccionUbicacion" managed="false" spacing="4" visible="false">
                                    <Label styleClass="form-field-label" text="Ubicación / Dirección" />
                                    <TextField fx:id="txtUbicacion" prefHeight="38" promptText="Ej: Av. Principal 123, Ciudad Obregón" style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 12; -fx-font-size: 13px;" />
                                </VBox>

                                <!-- ─── SELECTOR DE PADRE (empresa, sucursal, depto) ─── -->
                                <VBox fx:id="seccionPadre" managed="false" spacing="4" visible="false">
                                    <Label fx:id="lblPadre" styleClass="form-field-label" text="Empresa" />
                                    <javafx.scene.control.ComboBox fx:id="cbxPadre" maxWidth="1.7976931348623157E308" prefHeight="38" style="-fx-background-color: #F9FAFB; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-background-radius: 8;" />
                                    <Label fx:id="errPadre" managed="false" styleClass="label-error" visible="false" />
                                </VBox>

                                <!-- ─── BOTÓN GUARDAR ─── -->
                                <HBox alignment="CENTER_RIGHT" spacing="10">
                                    <Button fx:id="btnCancelarForm" onAction="#cancelarFormulario" prefHeight="38" prefWidth="100" styleClass="btn-cancelar" text="Cancelar" />
                                    <Button fx:id="btnGuardar" onAction="#guardarSeleccionado" prefHeight="38" prefWidth="130" styleClass="btn-agregar" text="Guardar" />
                                </HBox>

                                <!-- ─── SECCIÓN HIJOS (agregar nivel siguiente) ─── -->
                                <VBox fx:id="seccionHijos" managed="false" spacing="10" visible="false">
                                    <Separator />
                                    <Label fx:id="lblTituloHijos" style="-fx-font-weight: bold; -fx-font-size: 13px; -fx-text-fill: #374151;" text="Sucursales" />
                                    <!-- Lista de hijos existentes -->
                                    <VBox fx:id="listaHijos" spacing="6" />
                                    <!-- Botón añadir hijo -->
                                    <Button fx:id="btnAgregarHijo" maxWidth="1.7976931348623157E308" onAction="#agregarHijo" prefHeight="38" styleClass="btn-add-child" text="Agregar sucursal" />
                                </VBox>

                            </VBox>
                        </content>
                    </javafx.scene.control.ScrollPane>

                </VBox>

            </StackPane>

        </SplitPane>
    </center>

</BorderPane>
